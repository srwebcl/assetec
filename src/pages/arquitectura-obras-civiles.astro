---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const servicios = [
  {
    img: '/images/Servicios-de-Arquitectura-Assetec.webp',
    alt: 'Arquitectura y Diseño Assetec',
    titulo: 'Arquitectura y Diseño',
    texto:
      'Generamos servicios de arquitectura y diseño, ligadas a la ingeniería eléctrica. Ofrecemos el estudio y entrega de proyectos lumínicos desde su diseño hasta su construcción; con planimetría de alto estándar.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
  },
  {
    img: '/images/Gestion-de-Proyectos-Assetec.webp',
    alt: 'Gestión de Proyectos Assetec',
    titulo: 'Gestión de Proyectos',
    texto:
      'Nuestra experiencia en proyectos responde a una buena gestión en la tramitación. Tramitaciones de Factibilidades y Certificación de las instalaciones ante la SEC.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M9 14l2 2 4-4"/></svg>`,
  },
  {
    img: '/images/Servicio-de-Obras-Civiles-Assetec.webp',
    alt: 'Obras Civiles Assetec',
    titulo: 'Obras Civiles',
    texto:
      'Construcción de proyectos e infraestructura eléctrica. Contamos con supervisión y soporte total durante todo el proceso constructivo e ingenieril de los proyectos.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 20h20"/><path d="M5 20V8l7-4 7 4v12"/><path d="M9 20v-8h6v8"/></svg>`,
  },
  {
    img: '/images/Servicios-Integrales-Assetec.webp',
    alt: 'Servicios Integrales Assetec',
    titulo: 'Servicios Integrales',
    texto:
      'Equipo capacitado para trabajar en entornos de alta tensión con precisión y detalle. Presencia total ante obras de emergencia y de mantenimiento.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
];

const highlights = [
  { emoji: '🔌', texto: 'Diseño y ejecución de proyectos de integración' },
  { emoji: '⚡', texto: 'Implementación de estudios energéticos' },
  { emoji: '🏗️', texto: 'Ingeniería de proyectos y tramitaciones SEC' },
];
---

<Layout
  title="Arquitectura y Obras Civiles | Assetec"
  description="Soluciones integrales en proyectos eléctricos, de Arquitectura y Obras civiles en Chile. Diseño, ejecución y gestión de proyectos de alta calidad."
>
  <!-- HERO (Sincronizado con Nosotros/Ingeniería) -->
  <section class="page-hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1503387762-592dea58ef23?auto=format&fit=crop&q=80&w=1920"
        alt="Arquitectura y Obras Civiles Assetec"
        class="hero-img"
        loading="eager"
      />
      <div class="hero-overlay"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label hero-label">Innovación & Excelencia</span>
      <h1 class="page-title">
        Arquitectura &<br /><span class="accent">Obras Civiles</span>
      </h1>
      <p class="page-subtitle">
        Construyendo el futuro con innovación y excelencia en cada proyecto.
      </p>
    </div>
  </section>

  <!-- INTRO (Fondo Claro) -->
  <section class="intro-section light-section">
    <div class="container intro-inner">
      <div class="intro-text">
        <span class="section-label">¿Qué hacemos?</span>
        <h2 class="section-title">
          Soluciones Integrales para <span class="accent">Proyectos Complejos</span>
        </h2>
        <p class="intro-desc">
          En <strong>ASSETEC</strong>, nos enfocamos en brindar soluciones integrales en proyectos
          eléctricos, de <strong>Arquitectura y Obras civiles</strong>. Nuestro equipo de expertos
          cuenta con años de experiencia en diseño y ejecución de proyectos a lo largo del país de
          alta calidad para los sectores
          <strong>comercial, industrial y minero</strong> en Chile.
        </p>
        <ul class="highlight-list">
          {
            highlights.map((h) => (
              <li class="highlight-item">
                <span class="h-emoji">{h.emoji}</span>
                <span class="h-text">{h.texto}</span>
              </li>
            ))
          }
        </ul>
        <a href="/contacto" class="btn btn-primary">
          Solicitar Presupuesto
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="intro-visual">
        <div class="visual-card">
          <div class="vc-icon">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3 class="vc-title">Obras Civiles</h3>
          <p class="vc-sub">Arquitectura e Infraestructura</p>
          <div class="vc-divider"></div>
          <div class="vc-stats">
            <div class="vc-stat">
              <span class="vc-num">A+</span>
              <span class="vc-lbl">Calidad</span>
            </div>
            <div class="vc-stat-sep"></div>
            <div class="vc-stat">
              <span class="vc-num">ISO</span>
              <span class="vc-lbl">Normativa</span>
            </div>
            <div class="vc-stat-sep"></div>
            <div class="vc-stat">
              <span class="vc-num">+15</span>
              <span class="vc-lbl">Especialistas</span>
            </div>
          </div>
        </div>
        <div class="visual-deco-ring"></div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS NIVELADOS (Grid 2x2) -->
  <section class="servicios-section blue-section">
    <div class="container">
      <div class="servicios-header">
        <span class="section-label">Nuestros Servicios Integrales</span>
        <h2 class="section-title">
          Diseño y Ejecución<br /><span class="accent">Funcional</span>
        </h2>
        <p class="servicios-lead">
          Nuestros Arquitectos e Ingenieros están comprometidos con el diseño de espacios y
          estructuras innovadoras y funcionales. Desde la conceptualización hasta la ejecución,
          prestando servicios de ingeniería eléctrica, arquitectura y diseño y estudios técnicos
          especializados a todo cliente.
          <br /><br />
          Nuestra división de Obras Civiles (OO.CC.) ejecuta la fabricación y rehabilitación de espacios,
          lugares e infraestructuras complejas, con el fin de llevar a la realidad el servicio y el diseño
          fielmente a la necesidad del cliente.
        </p>
      </div>

      <div class="servicios-grid">
        {
          servicios.map((s, i) => (
            <article class="pro-card" style={`animation-delay: ${i * 0.12}s`}>
              <div class="card-media">
                <img src={s.img} alt={s.alt} class="card-img" />
                <div class="card-glow" />
              </div>
              <div class="card-overlay">
                <div class="card-content-area">
                  <div class="card-header">
                    <div class="card-icon" set:html={s.icono} />
                    <h3 class="card-title">{s.titulo}</h3>
                  </div>
                  <div class="card-body">
                    <p class="card-text">{s.texto}</p>
                    <div class="card-line" />
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  /* ── SHARED ── */
  .section-title {
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 32px;
    line-height: 1.1;
  }
  .accent {
    color: var(--color-primary);
  }

  /* ── SECTION BACKGROUNDS ── */
  .light-section {
    background: var(--color-off-white);
    color: var(--color-text-main);
  }
  .light-section .section-title {
    color: var(--color-blue-dark);
  }
  .light-section .intro-desc {
    color: var(--color-text-light);
  }
  .light-section .intro-desc strong {
    color: var(--color-blue-accent);
  }
  .light-section .highlight-item {
    background: rgba(42, 82, 152, 0.05);
    border-color: rgba(42, 82, 152, 0.1);
    color: var(--color-text-light);
  }

  .blue-section {
    background: var(--color-blue-deep);
    position: relative;
    color: var(--color-white);
    padding: 120px 0;
  }
  .blue-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(42, 82, 152, 0.15), transparent 70%);
    pointer-events: none;
  }

  /* ── HERO ── */
  .page-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
    background: var(--color-blue-dark);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenburns 25s ease infinite alternate;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 60% at 75% 50%, rgba(42, 82, 152, 0.2) 0%, transparent 60%),
      linear-gradient(
        to right,
        var(--color-blue-dark) 0%,
        var(--color-blue-base) 40%,
        rgba(11, 24, 41, 0.6) 80%,
        transparent 100%
      );
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
  }
  .hero-content {
    position: relative;
    z-index: 10;
    animation: fadeInUp 0.8s ease both;
  }
  .hero-label {
    color: var(--color-primary) !important;
  }
  .page-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-white);
    margin-bottom: 20px;
  }
  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
  }

  /* ── INTRO ── */
  .intro-section {
    padding: var(--section-padding);
    overflow: hidden;
  }
  .intro-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: center;
  }
  .intro-desc {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 32px;
  }
  .highlight-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 36px;
  }
  .highlight-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    border-radius: 8px;
    padding: 12px 16px;
    transition: var(--transition);
    font-weight: 600;
    font-family: var(--font-heading);
  }
  .highlight-item:hover {
    transform: translateX(6px);
  }

  /* Visual card */
  .intro-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .visual-card {
    background: linear-gradient(145deg, var(--color-blue-light), var(--color-blue-deep));
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
    width: 100%;
    max-width: 360px;
    position: relative;
    z-index: 2;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }
  .vc-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 204, 0, 0.1);
    border: 2px solid rgba(255, 204, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin: 0 auto 20px;
  }
  .vc-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 6px;
  }
  .vc-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vc-divider {
    width: 48px;
    height: 1px;
    background: rgba(255, 204, 0, 0.3);
    margin: 24px auto;
  }
  .vc-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
  .vc-stat {
    text-align: center;
  }
  .vc-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  .vc-lbl {
    display: block;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 4px;
  }
  .vc-stat-sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.08);
  }
  .visual-deco-ring {
    position: absolute;
    width: 110%;
    height: 110%;
    border-radius: 50%;
    border: 1px solid rgba(255, 204, 0, 0.1);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: pulse-ring 4s ease infinite;
  }

  /* ── GRID DE SERVICIOS (4 TARJETAS NIVELADAS) ── */
  .servicios-header {
    margin-bottom: 60px;
    max-width: 800px;
  }
  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  @media (max-width: 900px) {
    .servicios-grid {
      grid-template-columns: 1fr;
    }
  }

  .pro-card {
    height: 520px;
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #050d1a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .pro-card:hover {
    transform: translateY(-12px);
    border-color: rgba(255, 204, 0, 0.4);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
  }

  .card-media {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9) contrast(1.1);
    transition: transform 1.2s ease;
  }
  .pro-card:hover .card-img {
    transform: scale(1.08);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 17, 36, 0.1) 0%,
      rgba(5, 17, 36, 0.4) 40%,
      rgba(5, 17, 36, 0.95) 85%,
      rgba(5, 17, 36, 1) 100%
    );
    z-index: 2;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .card-content-area {
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .card-icon {
    width: 52px;
    height: 52px;
    background: var(--color-primary);
    color: #051124;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(255, 204, 0, 0.3);
    flex-shrink: 0;
  }
  .card-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .card-body {
    height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-line {
    width: 0;
    height: 4px;
    background: var(--color-primary);
    transition: width 0.7s ease;
  }
  .pro-card:hover .card-line {
    width: 100%;
  }

  /* ── ANIMATIONS ── */
  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }
  @keyframes pulse-ring {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.05);
      opacity: 0.2;
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
  }
</style>
