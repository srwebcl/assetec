---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Assetec">
  <section class="not-found">
    <div class="nf-bg"></div>
    <div class="container nf-inner">
      <span class="nf-code">404</span>
      <h1 class="nf-title">Página no encontrada</h1>
      <p class="nf-text">Lo sentimos, la página que buscas no existe o fue movida.</p>
      <a href="/" class="btn btn-primary">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        Volver al inicio
      </a>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-dark);
    overflow: hidden;
    padding-top: var(--nav-height);
  }
  .nf-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 60% at 50% 50%,
      rgba(232, 180, 0, 0.05) 0%,
      transparent 60%
    );
  }
  .nf-inner {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .nf-code {
    display: block;
    font-family: var(--font-heading);
    font-size: 10rem;
    font-weight: 900;
    line-height: 1;
    color: rgba(232, 180, 0, 0.12);
    letter-spacing: -0.05em;
    margin-bottom: -20px;
  }
  .nf-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .nf-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 40px;
  }
</style>
