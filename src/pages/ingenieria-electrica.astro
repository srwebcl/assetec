---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const servicios = [
  {
    img: '/images/Ingenieria.webp',
    alt: 'Ingeniería Eléctrica Assetec',
    titulo: 'Ingeniería',
    texto:
      'Diseñamos proyectos de acuerdo a su necesidad, planos, especificaciones técnicas, diseño de iluminación, sistemas de puesta a tierra, tramitación de empalmes, levantamientos e informes técnicos.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 20h20M4 20V10l8-6 8 6v10"/><path d="M10 20v-6h4v6"/></svg>`,
  },
  {
    img: '/images/Montaje.webp',
    alt: 'Montaje Eléctrico Assetec',
    titulo: 'Montaje',
    texto:
      'Ejecutamos todo tipo de sistema eléctrico, subestaciones, empalmes, transformadores, grupos generadores, tableros eléctricos, banco de ductos, ductos de barras, sistemas de puesta a tierra, distribución de canalizaciones y cableado.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12(2.12) 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    img: '/images/Manteniemiento.webp',
    alt: 'Mantenimiento Eléctrico Assetec',
    titulo: 'Mantenimiento',
    texto:
      'Realizamos mantenimiento predictivo, preventivo y correctivo a todas las instalaciones eléctricas, tableros, transformadores, grupos generadores, etc. Ocupamos instrumentación para realizar análisis de red y calidad de energía, termografías, pruebas de aislamiento, niveles de iluminación, etc.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    img: '/images/CDD.webp',
    alt: 'Corrientes Débiles CCDD Assetec',
    titulo: 'Corrientes Débiles',
    texto:
      'Diseñamos y ejecutamos proyectos de CCDD, centrales, rack, acometidas, canalizaciones y cableado estructurado.',
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M6 6h.01M6 18h.01"/></svg>`,
  },
];

const highlights = [
  { emoji: '🔌', texto: 'Proyectos eléctricos personalizados' },
  { emoji: '⚡', texto: 'Eficiencia energética y seguridad' },
  { emoji: '🏗️', texto: 'Soluciones para empresas, industrias y minería' },
];
---

<Layout
  title="Ingeniería Eléctrica | Assetec"
  description="Servicios de ingeniería eléctrica de alta calidad para sectores comercial, industrial y minero. Diseño, montaje, mantenimiento y corrientes débiles."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="hero-bg">
      <img
        src="/images/Ingenieria.webp"
        alt="Ingeniería Eléctrica Assetec"
        class="hero-img"
        loading="eager"
      />
      <div class="hero-overlay"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label hero-label">Certificación SEC</span>
      <h1 class="page-title">
        Ingeniería<br /><span class="accent">Eléctrica</span>
      </h1>
      <p class="page-subtitle">Soluciones Eléctricas Innovadoras, Seguras y Eficientes</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="intro-section light-section">
    <div class="container intro-inner">
      <div class="intro-text">
        <span class="section-label">¿Qué hacemos?</span>
        <h2 class="section-title">
          Soluciones Eléctricas para <span class="accent">cada necesidad</span>
        </h2>
        <p class="intro-desc">
          En <strong>ASSETEC</strong>, ofrecemos <strong
            >servicios de ingeniería eléctrica de alta calidad</strong
          >, diseñados para optimizar la eficiencia energética y garantizar la seguridad en cada
          instalación. Nos especializamos en
          <strong>diseño, implementación y mantenimiento</strong> de sistemas eléctricos para los sectores
          <strong>comercial, industrial y minero</strong> en Chile.
        </p>
        <ul class="highlight-list">
          {
            highlights.map((h) => (
              <li class="highlight-item">
                <span class="h-emoji">{h.emoji}</span>
                <span class="h-text">{h.texto}</span>
              </li>
            ))
          }
        </ul>
        <a href="/contacto" class="btn btn-primary">
          Solicitar Presupuesto
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="intro-visual">
        <div class="visual-card">
          <div class="vc-icon">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
            </svg>
          </div>
          <h3 class="vc-title">Ingeniería Eléctrica</h3>
          <p class="vc-sub">Sector Comercial, Industrial y Minero</p>
          <div class="vc-divider"></div>
          <div class="vc-stats">
            <div class="vc-stat">
              <span class="vc-num">4</span>
              <span class="vc-lbl">Servicios</span>
            </div>
            <div class="vc-stat-sep"></div>
            <div class="vc-stat">
              <span class="vc-num">SEC</span>
              <span class="vc-lbl">Certificado</span>
            </div>
            <div class="vc-stat-sep"></div>
            <div class="vc-stat">
              <span class="vc-num">+8</span>
              <span class="vc-lbl">Años</span>
            </div>
          </div>
        </div>
        <div class="visual-deco-ring"></div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS REFINADOS (4 TARJETAS NIVELADAS) -->
  <section class="servicios-section blue-section">
    <div class="container">
      <div class="servicios-header">
        <span class="section-label">Portafolio Energético</span>
        <h2 class="section-title">
          ¿En qué podemos<br /><span class="accent">ayudarte?</span>
        </h2>
        <p class="servicios-lead">
          Experiencia y precisión en cada etapa del ciclo energético de su proyecto.
        </p>
      </div>

      <div class="servicios-grid">
        {
          servicios.map((s, i) => (
            <article class="pro-card" style={`animation-delay: ${i * 0.12}s`}>
              <div class="card-media">
                <img src={s.img} alt={s.alt} class="card-img" />
                <div class="card-glow" />
              </div>
              <div class="card-overlay">
                <div class="card-content-area">
                  <div class="card-header">
                    <div class="card-icon" set:html={s.icono} />
                    <h3 class="card-title">{s.titulo}</h3>
                  </div>
                  <div class="card-body">
                    <p class="card-text">{s.texto}</p>
                    <div class="card-line" />
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  /* ── SHARED ── */
  .section-title {
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 32px;
    line-height: 1.1;
  }
  .accent {
    color: var(--color-primary);
  }

  /* ── SECTION BACKGROUNDS ── */
  .light-section {
    background: var(--color-off-white);
    color: var(--color-text-main);
  }
  .light-section .section-title {
    color: var(--color-blue-dark);
  }
  .light-section .intro-desc {
    color: var(--color-text-light);
  }
  .light-section .intro-desc strong {
    color: var(--color-blue-accent);
  }
  .light-section .highlight-item {
    background: rgba(42, 82, 152, 0.05);
    border-color: rgba(42, 82, 152, 0.1);
    color: var(--color-text-light);
  }

  .blue-section {
    background: var(--color-blue-deep);
    position: relative;
    color: var(--color-white);
    padding: 120px 0;
  }
  .blue-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(42, 82, 152, 0.15), transparent 70%);
    pointer-events: none;
  }

  /* ── HERO ── */
  .page-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
    background: var(--color-blue-dark);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenburns 25s ease infinite alternate;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 60% at 75% 50%, rgba(42, 82, 152, 0.2) 0%, transparent 60%),
      linear-gradient(
        to right,
        var(--color-blue-dark) 0%,
        var(--color-blue-base) 40%,
        rgba(11, 24, 41, 0.6) 80%,
        transparent 100%
      );
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
  }
  .hero-content {
    position: relative;
    z-index: 10;
    animation: fadeInUp 0.8s ease both;
  }
  .hero-label {
    color: var(--color-primary) !important;
  }
  .page-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-white);
    margin-bottom: 20px;
  }
  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
  }

  /* ── INTRO ── */
  .intro-section {
    padding: var(--section-padding);
    overflow: hidden;
  }
  .intro-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: center;
  }
  .intro-desc {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 32px;
  }
  .highlight-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 36px;
  }
  .highlight-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    border-radius: 8px;
    padding: 12px 16px;
    transition: var(--transition);
    font-weight: 600;
    font-family: var(--font-heading);
  }
  .highlight-item:hover {
    transform: translateX(6px);
  }

  /* Visual card */
  .intro-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .visual-card {
    background: linear-gradient(145deg, var(--color-blue-light), var(--color-blue-deep));
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
    width: 100%;
    max-width: 360px;
    position: relative;
    z-index: 2;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }
  .vc-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 204, 0, 0.1);
    border: 2px solid rgba(255, 204, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin: 0 auto 20px;
  }
  .vc-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-white);
    margin-bottom: 6px;
  }
  .vc-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .vc-divider {
    width: 48px;
    height: 1px;
    background: rgba(255, 204, 0, 0.3);
    margin: 24px auto;
  }
  .vc-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
  .vc-stat {
    text-align: center;
  }
  .vc-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  .vc-lbl {
    display: block;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 4px;
  }
  .vc-stat-sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.08);
  }
  .visual-deco-ring {
    position: absolute;
    width: 110%;
    height: 110%;
    border-radius: 50%;
    border: 1px solid rgba(255, 204, 0, 0.1);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: pulse-ring 4s ease infinite;
  }

  /* ── REFINED GRID DE SERVICIOS (4 TARJETAS NIVELADAS) ── */
  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  @media (max-width: 900px) {
    .servicios-grid {
      grid-template-columns: 1fr;
    }
  }

  .pro-card {
    height: 520px; /* Aumentado ligeramente para mejor proporción */
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #050d1a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    animation: fadeInUp 0.8s ease both;
  }

  .pro-card:hover {
    transform: translateY(-12px);
    border-color: rgba(255, 204, 0, 0.4);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
  }

  .card-media {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9) contrast(1.1); /* Imagen más clara arriba */
    transition: transform 1.2s ease;
  }
  .pro-card:hover .card-img {
    transform: scale(1.08);
  }

  /* Gradiente más fuerte abajo para legibilidad */
  .card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 17, 36, 0.1) 0%,
      rgba(5, 17, 36, 0.4) 40%,
      rgba(5, 17, 36, 0.95) 85%,
      rgba(5, 17, 36, 1) 100%
    );
    z-index: 2;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* Área de contenido con altura mínima para nivelar textos */
  .card-content-area {
    min-height: 240px; /* Asegura que todos los textos empiecen a la misma altura relativa */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .card-icon {
    width: 52px;
    height: 52px;
    background: var(--color-primary);
    color: #051124;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(255, 204, 0, 0.3);
    flex-shrink: 0;
  }
  .card-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .card-body {
    height: 120px; /* Altura fija para el cuerpo del texto para nivelar visualmente */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: 20px;
    /* Limitamos a 3 líneas para que todas las tarjetas se vean iguales */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-line {
    width: 0;
    height: 4px;
    background: var(--color-primary);
    transition: width 0.7s ease;
  }
  .pro-card:hover .card-line {
    width: 100%;
  }

  @media (max-width: 640px) {
    .card-title {
      font-size: 1.5rem;
    }
    .card-overlay {
      padding: 30px;
    }
  }

  /* ── ANIMATIONS ── */
  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }
  @keyframes pulse-ring {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.05);
      opacity: 0.2;
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
  }
</style>
