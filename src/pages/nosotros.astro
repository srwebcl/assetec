---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const pilares = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    titulo: 'Respaldo',
    texto:
      'Contamos con personal capacitado y con experiencia en distintos campos del rubro de la energía, la arquitectura y obras civiles.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    titulo: 'Prestaciones',
    texto:
      'Asesorías Eléctricas y Servicios Técnicos ligado al diseño, confección y posterior construcción, según lo que necesitan nuestros clientes.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    titulo: 'Compromiso',
    texto:
      'Damos especial énfasis en la capacitación constante de nuestros colaboradores, con el objeto de desempeñarnos con altos estándares de calidad y de protección del medio.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    titulo: 'Cultura Energética',
    texto:
      'El ahorro y la eficiencia energética es nuestro principal valor agregado en nuestras obras.',
  },
];
---

<Layout
  title="Nosotros | Assetec"
  description="Empresa chilena especializada en ingeniería eléctrica, arquitectura y obras civiles, con más de 6 años de experiencia."
>
  <!-- HERO (Estilo Index OK) -->
  <section class="page-hero">
    <div class="hero-bg">
      <img
        src="/images/Profesionales-Assetec-Empresa-Electrica.webp"
        alt="Equipo Assetec"
        class="hero-img"
        loading="eager"
      />
      <div class="hero-overlay"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <span class="section-label hero-label">Especialistas en Energía</span>
      <h1 class="page-title">Nosotros</h1>
      <p class="page-subtitle">Innovación y Compromiso en Ingeniería Eléctrica y Arquitectura</p>
    </div>
  </section>

  <!-- INTRO (Fondo Claro Intercalado - Corregido texto blanco) -->
  <section class="about-section light-section">
    <div class="container about-inner">
      <div class="about-content">
        <span class="section-label">ASSETEC Chile</span>
        <h2 class="section-title">
          Innovación y Compromiso en<br /><span class="accent"
            >Ingeniería Eléctrica y Arquitectura</span>
        </h2>
        <div class="about-text">
          <p>
            En <strong>ASSETEC</strong>, somos una empresa chilena especializada en
            <strong>ingeniería eléctrica, arquitectura y obras civiles</strong>, con más de 8 años
            de experiencia brindando soluciones eficientes y seguras para el sector
            <strong>comercial, industrial y minero</strong>.
          </p>
          <p>
            Desde nuestra fundación en <strong>2018 en La Serena</strong>, hemos evolucionado para
            ofrecer proyectos <strong>innovadores y sostenibles</strong>, garantizando
            <strong>calidad, eficiencia energética y seguridad</strong> en cada obra que realizamos.
          </p>
        </div>

        <div class="intro-stats">
          <div class="stat-box">
            <span class="stat-num">2018</span>
            <span class="stat-lbl">Año de fundación</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">+8</span>
            <span class="stat-lbl">Años de experiencia</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">SEC</span>
            <span class="stat-lbl">Certificados</span>
          </div>
        </div>
      </div>

      <div class="about-visual">
        <div class="about-img-wrap">
          <img
            src="/images/Ingenieria-Electrica-La-Serena.webp"
            alt="Ingeniería Eléctrica Assetec"
            loading="lazy"
            class="about-img"
          />
          <div class="about-img-overlay"></div>
        </div>
        <div class="about-badge-float">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          <div>
            <span class="float-title">Calidad & Seguridad</span>
            <span class="float-sub">Estándares Internacionales</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORIA (Fondo Azul Requerido) -->
  <section class="historia-section blue-section">
    <div class="container">
      <div class="historia-top">
        <span class="section-label">Nuestra Historia</span>
        <h2 class="section-title">
          Innovando en Ingeniería Eléctrica <span class="accent">desde 2018</span>
        </h2>
      </div>

      <div class="historia-grid">
        <div class="historia-images">
          <div class="img-main-wrap">
            <img
              src="/images/Profesionales-Assetec-Empresa-Electrica.webp"
              alt="Profesionales Assetec"
              loading="lazy"
              class="himg-main"
            />
          </div>
          <img
            src="/images/Equipo-Assetec-Empresa-Electrica.webp"
            alt="Equipo Assetec"
            loading="lazy"
            class="himg-secondary"
          />
          <div class="historia-badge">
            <span class="badge-year">2018</span>
            <span class="badge-text">Origen ASSETEC</span>
          </div>
        </div>

        <div class="historia-body">
          <div class="historia-text-wrap">
            <p>
              ASSETEC nació en <strong>2018</strong> de la visión de
              <strong>de un joven empresario local</strong>, que integró su creatividad con la innovación
               del mercado y su capacidad de planificar y trabajar hacia un futuro sostenible con el objetivo de
              <strong>revolucionar el sector eléctrico en Chile</strong>. Iniciamos prestando
              servicios eléctricos a <strong>particulares y empresas</strong>, y con el tiempo, nos
              expandimos al área de
              <strong>arquitectura y construcción</strong>, ofreciendo
              <strong>soluciones integrales y personalizadas</strong>.
            </p>
            <p>
              Hoy, con una trayectoria consolidada, seguimos creciendo y perfeccionando nuestras
              metodologías para ofrecer
              <strong>proyectos innovadores, eficientes y sostenibles</strong>.
            </p>
          </div>

          <div class="mv-grid">
            <div class="mv-card">
              <div class="mv-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                </svg>
              </div>
              <div class="mv-content">
                <h4 class="mv-title">Misión</h4>
                <p class="mv-text">
                  Somos un equipo de personas comprometidas con el servicio a nuestros clientes en
                  el sector energético. Mediante nuestra especialización tecnológica, ejecutamos con
                  eficiencia, calidad, seguridad y sustentabilidad cada uno de nuestros proyectos y
                  trabajos.
                </p>
              </div>
            </div>
            <div class="mv-card">
              <div class="mv-icon">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </div>
              <div class="mv-content">
                <h4 class="mv-title">Visión</h4>
                <p class="mv-text">
                  Ser reconocido por los clientes como el facilitador líder en soluciones integrales
                  para la utilización de la energía, con calidad, tecnología e innovación,
                  cumpliendo un rol trascendente en el desarrollo de la sociedad.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PILARES (Fondo Oscuro Profundo para contraste) -->
  <section class="pilares-section">
    <div class="container">
      <div class="pilares-header">
        <span class="section-label">Nuestra Cultura</span>
        <h2 class="section-title">Lo que nos define</h2>
      </div>
      <div class="pilares-grid">
        {
          pilares.map((p, i) => (
            <div class="pilar-card" style={`animation-delay: ${i * 0.1}s`}>
              <div class="pilar-icon" set:html={p.icon} />
              <h3 class="pilar-titulo">{p.titulo}</h3>
              <p class="pilar-texto">{p.texto}</p>
              <div class="pilar-line" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  /* ── SHARED ── */
  .section-title {
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 32px;
    line-height: 1.1;
  }
  .accent {
    color: var(--color-primary);
  }

  /* ── SECTION BACKGROUNDS ── */
  .light-section {
    background: var(--color-off-white);
    color: var(--color-text-main);
  }
  .light-section .section-title {
    color: var(--color-blue-dark);
  }
  .light-section .about-text {
    color: var(--color-text-light);
  }
  .light-section .about-text strong {
    color: var(--color-blue-accent);
  }

  .blue-section {
    background: var(--color-blue-deep);
    position: relative;
    color: var(--color-white);
  }
  .blue-section .section-title {
    color: var(--color-white);
  }
  .blue-section .historia-text-wrap {
    color: rgba(255, 255, 255, 0.8);
  }
  .blue-section .historia-text-wrap strong {
    color: var(--color-white);
  }

  .blue-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(42, 82, 152, 0.15), transparent 70%);
    pointer-events: none;
  }

  /* ── HERO (Estilo Index) ── */
  .page-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
    background: var(--color-blue-dark);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenburns 25s ease infinite alternate;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 60% at 75% 50%, rgba(42, 82, 152, 0.2) 0%, transparent 60%),
      linear-gradient(
        to right,
        var(--color-blue-dark) 0%,
        var(--color-blue-base) 40%,
        rgba(11, 24, 41, 0.6) 80%,
        transparent 100%
      );
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 80%);
  }
  .hero-content {
    position: relative;
    z-index: 10;
    animation: fadeInUp 0.8s ease both;
  }
  .hero-label {
    color: var(--color-primary) !important;
  }
  .page-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-white);
    margin-bottom: 20px;
  }
  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
  }

  /* ── ABOUT SECTION ── */
  .about-section {
    padding: var(--section-padding);
    overflow: hidden;
  }
  .about-inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: center;
  }
  .about-text {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .intro-stats {
    display: flex;
    gap: 1px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-border);
    box-shadow: var(--shadow);
    margin-top: 40px;
  }
  .stat-box {
    flex: 1;
    padding: 24px;
    text-align: center;
    background: var(--color-white);
  }
  .stat-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-bottom: 4px;
  }
  .stat-lbl {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    opacity: 0.7;
  }

  .about-visual {
    position: relative;
  }
  .about-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(8, 17, 31, 0.15);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .about-img {
    width: 100%;
    height: 540px;
    object-fit: cover;
    transition: transform 0.8s ease;
  }
  .about-img-wrap:hover .about-img {
    transform: scale(1.05);
  }
  .about-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 21, 48, 0.2), transparent);
  }
  .about-badge-float {
    position: absolute;
    bottom: -20px;
    left: -20px;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--color-blue-dark);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    color: var(--color-primary);
    animation: fadeInUp 0.8s ease 0.3s both;
  }
  .float-title {
    display: block;
    font-weight: 700;
    color: var(--color-white);
    font-size: 0.85rem;
  }
  .float-sub {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── HISTORIA ── */
  .historia-section {
    padding: var(--section-padding);
  }
  .historia-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .historia-images {
    position: relative;
    padding-bottom: 60px;
  }
  .img-main-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .himg-main {
    width: 100%;
    height: 440px;
    object-fit: cover;
  }
  .himg-secondary {
    position: absolute;
    bottom: 0;
    right: -40px;
    width: 60%;
    height: 240px;
    object-fit: cover;
    border-radius: 12px;
    border: 4px solid var(--color-blue-deep);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
  .historia-badge {
    position: absolute;
    top: 30px;
    left: -20px;
    background: var(--color-primary);
    padding: 12px 20px;
    border-radius: 8px;
    box-shadow: var(--shadow-gold);
    color: var(--color-blue-dark);
  }
  .badge-year {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
  }
  .badge-text {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .historia-text-wrap {
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 40px;
  }

  .mv-grid {
    display: grid;
    gap: 20px;
  }
  .mv-card {
    display: flex;
    gap: 20px;
    background: var(--color-blue-light);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 28px;
    transition: var(--transition);
  }
  .mv-card:hover {
    border-color: rgba(255, 204, 0, 0.3);
    transform: translateX(8px);
  }
  .mv-icon {
    width: 44px;
    height: 44px;
    background: rgba(255, 204, 0, 0.1);
    border: 1px solid rgba(255, 204, 0, 0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .mv-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 8px;
    font-weight: 700;
  }
  .mv-text {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
  }

  /* ── PILARES ── */
  .pilares-section {
    padding: var(--section-padding);
    background: var(--color-blue-base);
  }
  .pilares-header {
    margin-bottom: 56px;
    text-align: center;
  }
  .pilares-header .section-title {
    color: var(--color-white);
  }

  .pilares-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .pilar-card {
    position: relative;
    background: var(--color-blue-dark);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 40px 30px;
    overflow: hidden;
    transition: var(--transition);
    animation: fadeInUp 0.6s ease both;
  }
  .pilar-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
  }
  .pilar-icon {
    display: inline-flex;
    margin-bottom: 24px;
    color: var(--color-primary);
    background: rgba(255, 204, 0, 0.1);
    padding: 12px;
    border-radius: 12px;
  }
  .pilar-titulo {
    font-size: 1.2rem;
    color: var(--color-white);
    margin-bottom: 12px;
    font-weight: 700;
  }
  .pilar-texto {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
  }

  .pilar-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--color-primary);
    transition: width 0.4s ease;
  }
  .pilar-card:hover .pilar-line {
    width: 100%;
  }

  /* ── ANIMATIONS ── */
  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .about-inner,
    .historia-grid {
      gap: 40px;
    }
    .pilares-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 900px) {
    .about-inner,
    .historia-grid {
      grid-template-columns: 1fr;
    }
    .about-visual,
    .historia-images {
      order: -1;
    }
    .himg-secondary {
      position: relative;
      width: 100%;
      right: 0;
      margin-top: -60px;
      height: 300px;
    }
    .about-img {
      height: 400px;
    }
  }
  @media (max-width: 640px) {
    .pilares-grid {
      grid-template-columns: 1fr;
    }
    .intro-stats {
      flex-direction: column;
    }
    .stat-box {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
    .about-badge-float {
      left: 10px;
      bottom: -20px;
      padding: 12px 16px;
    }
  }
</style>
