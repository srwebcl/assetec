---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Assetec | Ingeniería Eléctrica, Arquitectura y Proyectos',
  description = 'Desde 2018, ASSETEC se ha consolidado como líder en soluciones eléctricas y proyectos de arquitectura y obras civiles en La Serena, Chile.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/images/favicon.webp" type="image/webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsApp />
  </body>
</html>
