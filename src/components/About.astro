---
const features = [
  'Soluciones seguras y sostenibles',
  'Comprometidos con el medioambiente',
  'Expertos en diseño arquitectónico y construcción de alta calidad',
];
---

<section class="about" id="nosotros">
  <div class="about-bg">
    <div class="about-grid"></div>
    <div class="about-light-gold top-right"></div>
    <div class="about-light-gold bottom-left"></div>
  </div>

  <div class="container about-inner">
    <div class="about-content">
      <span class="section-label about-label">EMPRESA ELÉCTRICA</span>
      <h2 class="about-title">
        INGENIERÍA, ARQUITECTURA<br />
        <span class="about-title-accent">&amp; OBRAS CIVILES</span>
      </h2>
      <p class="about-text">
        Desde 2018, <strong>ASSETEC</strong> se ha consolidado como líder en soluciones eléctricas y proyectos
        de arquitectura y obras civiles. Ubicados en La Serena, aportamos innovación, eficiencia y compromiso
        en cada proyecto, abarcando desde el sector residencial hasta la industria y minería.
      </p>

      <ul class="about-features">
        {
          features.map((f) => (
            <li class="feature-item">
              <span class="feature-check">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="4"
                >
                  <path d="M20 6L9 17l-5-5" />
                </svg>
              </span>
              {f}
            </li>
          ))
        }
      </ul>

      <a href="/nosotros" class="btn btn-primary">Conoce nuestra Historia</a>
    </div>

    <div class="about-visual">
      <div class="about-img-wrap">
        <img
          src="/images/Ingenieria-Electrica-La-Serena.webp"
          alt="Ingeniería Eléctrica La Serena"
          loading="lazy"
          class="about-img"
        />
        <div class="about-img-overlay"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding: var(--section-padding);
    background: #0a1530; /* Azul Marino Profundo de la paleta */
    overflow: hidden;
  }

  .about-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .about-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(42, 82, 152, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(42, 82, 152, 0.08) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(ellipse 60% 70% at 50% 50%, black 20%, transparent 80%);
  }

  .about-light-gold {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 215, 0, 0.05) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }
  .about-light-gold.top-right {
    top: -200px;
    right: -200px;
  }
  .about-light-gold.bottom-left {
    bottom: -200px;
    left: -200px;
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .about-label {
    color: var(--color-primary) !important; /* Dorado Eléctrico */
    font-weight: 700;
  }
  .about-label::before {
    background: var(--color-primary);
  }

  .about-title {
    text-transform: uppercase;
    font-size: clamp(2.2rem, 4vw, 2.8rem);
    color: #ffffff !important;
    letter-spacing: 0.03em;
    margin-bottom: 28px;
    line-height: 1.1;
    font-weight: 800 !important;
  }

  .about-title-accent {
    color: var(--color-primary) !important;
  }

  /* MODIFICADO: Párrafo más grande y claro */
  .about-text {
    font-size: 1.15rem; /* Tamaño aumentado */
    color: #cbd5e1 !important; /* Gris azulado muy claro para contraste alto */
    line-height: 1.7;
    margin-bottom: 36px;
    font-weight: 400;
  }

  .about-text strong {
    color: #ffffff;
    font-weight: 700;
  }

  .about-features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 48px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 1.05rem;
    color: #f8fafc;
    font-weight: 500;
  }

  .feature-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    min-width: 22px;
    border-radius: 50%;
    background: rgba(255, 215, 0, 0.15);
    border: 1px solid rgba(255, 215, 0, 0.4);
    color: var(--color-primary);
  }

  /* --- VISUAL LIMPÌO Y PROFESIONAL --- */
  .about-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .about-img-wrap {
    position: relative;
    width: 100%;
    max-width: 550px;
    border-radius: 12px; /* Bordes redondeados limpios */
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5); /* Sombra pesada para dar profundidad */
    border: 1px solid rgba(255, 255, 255, 0.1); /* Borde casi invisible */
  }

  .about-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .about-img-wrap:hover .about-img {
    transform: scale(1.05);
  }

  .about-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 21, 48, 0.3), transparent);
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .about-visual {
      order: -1;
    }
    .about-img {
      height: 350px;
    }
  }
</style>
