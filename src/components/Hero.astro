---

---

<section class="hero" id="inicio">
  <div class="hero-bg">
    <img
      src="/images/hero.jpg"
      alt="Fondo de Ingeniería Eléctrica Assetec"
      class="hero-img"
      loading="eager"
    />

    <div class="hero-overlay"></div>

    <div class="hero-grid"></div>
  </div>

  <div class="container hero-content">
    <h1 class="hero-title">
      Ingeniería<br />
      <span class="hero-title-accent">Eléctrica</span>
    </h1>
    <p class="hero-subtitle">Servicio de Ingeniería Eléctrica para el sector público y privado</p>
    <div class="hero-cta">
      <a href="#servicios" class="btn btn-primary">
        Servicios
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path d="M7 13l5 5 5-5M7 6l5 5 5-5"></path>
        </svg>
      </a>
      <a href="/nosotros" class="btn btn-outline">Nosotros</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-blue-dark); /* Color base corporativo */
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden; /* Importante para que la imagen escalada no se salga */
  }

  /* Imagen de fondo con efecto Ken Burns */
  .hero-img {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    animation: kenburns 25s ease infinite alternate;
  }

  /* Capa oscura desvanecida */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      /* Brillo dorado sutil */
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(200, 168, 75, 0.12) 0%, transparent 60%),
      /* Gradiente principal: Azul oscuro corporativo -> Transparente hacia la derecha */
      linear-gradient(
          to right,
          var(--color-blue-dark) 0%,
          var(--color-blue-base) 35%,
          rgba(11, 24, 41, 0.5) 60%,
          transparent 100%
        ) !important;
  }

  /* Patrón de cuadrícula */
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    padding-top: var(--nav-height);
    animation: fadeInUp 0.9s ease both;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-white) !important; /* Forzamos blanco para resaltar */
    margin-bottom: 24px;
    animation: fadeInUp 0.8s ease 0.2s both;
  }

  .hero-title-accent {
    color: var(--color-primary) !important;
    position: relative;
    display: inline-block;
  }

  .hero-title-accent::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--color-primary);
    opacity: 0.3;
    border-radius: 2px;
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 1.5rem); /* Subtítulo grande */
    color: rgba(255, 255, 255, 0.85) !important;
    max-width: 600px;
    margin-bottom: 48px; /* Más aire al no haber elementos debajo */
    line-height: 1.6;
    animation: fadeInUp 0.8s ease 0.3s both;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 64px;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  /* Animación Ken Burns (acercamiento suave) */
  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }

  /* RESPONSIVE MÓVIL */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }

    .hero-overlay {
      background: linear-gradient(
        to bottom,
        var(--color-blue-dark) 0%,
        rgba(11, 24, 41, 0.8) 50%,
        var(--color-blue-dark) 100%
      ) !important;
    }

    /* 🔥 SOLUCIÓN PARA QUE LOS BOTONES QUEDEN UNO AL LADO DEL OTRO 🔥 */
    .hero-cta {
      flex-wrap: nowrap; /* Evita que pasen a dos líneas */
      gap: 12px; /* Reducimos un poco el espacio entre botones */
      width: 100%; /* Ocupan todo el ancho disponible del contenedor */
    }

    .hero-cta .btn {
      flex: 1; /* Cada botón ocupa el 50% */
      padding: 12px 0; /* Ajustamos el padding lateral para que quepan bien */
      font-size: 0.75rem; /* Letra ligeramente más pequeña para evitar desbordes */
      justify-content: center; /* Centramos el texto dentro del botón */
    }
  }
</style>
