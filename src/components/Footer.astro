---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/ingenieria-electrica', label: 'Ingeniería Eléctrica' },
  { href: '/arquitectura-obras-civiles', label: 'Arquitectura y Obras Civiles' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/contacto', label: 'Contacto' },
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="container footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img
            src="/images/Logo-Assetec.webp"
            alt="Assetec"
            width="160"
            height="50"
            loading="lazy"
          />
        </a>
        <p class="footer-tagline">
          Ingeniería Eléctrica, Arquitectura y Proyectos para el sector público y privado en La
          Serena, Chile.
        </p>
        <div class="footer-socials">
          <a
            href="https://wa.me/56965102370"
            target="_blank"
            rel="noopener"
            class="social-link"
            aria-label="WhatsApp"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-nav">
        <h4 class="footer-heading">Navegación</h4>
        <ul class="footer-links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  <span class="link-arrow">→</span>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-contact">
        <h4 class="footer-heading">Información</h4>
        <ul class="contact-list">
          <li class="contact-item">
            <span class="contact-icon">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </span>
            <div class="contact-details">
              <strong>CASA MATRIZ</strong>
              <span>Camino alfalfares s/n, La Serena. Región Coquimbo</span>
            </div>
          </li>
          <li class="contact-item">
            <span class="contact-icon">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <div class="contact-details">
              <strong>CORREO</strong>
              <a href="mailto:contacto@assetec.cl">contacto@assetec.cl</a>
            </div>
          </li>
          <li class="contact-item">
            <span class="contact-icon">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 7.81 19.79 19.79 0 01.36 5.2 2 2 0 012.3 3h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 10.8A16 16 0 0013.2 17.1l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0121 17v-.08z"
                ></path>
              </svg>
            </span>
            <div class="contact-details">
              <strong>TELEFONO CENTRAL</strong>
              <a href="tel:+56965102370">+569 6510 2370</a>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} ASSETEC. Todos los derechos reservados.
      </p>
      <p class="footer-credit">
        Sitio web desarrollado por <a href="https://www.srweb.cl" target="_blank" rel="noopener"
          >SRweb</a
        >
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark-4);
    border-top: 1px solid var(--color-border);
  }

  .footer-top {
    padding: 70px 0 50px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 60px;
  }

  .footer-logo img {
    height: 44px;
    width: auto;
    margin-bottom: 20px;
    filter: brightness(1.05);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 320px;
  }

  .footer-socials {
    display: flex;
    gap: 10px;
  }

  .social-link {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    transition: var(--transition);
  }

  .social-link:hover {
    background: rgba(232, 180, 0, 0.1);
    border-color: rgba(232, 180, 0, 0.3);
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    transition: var(--transition);
    padding: 4px 0;
  }

  .link-arrow {
    color: var(--color-primary);
    font-size: 0.8rem;
    opacity: 0;
    transition: var(--transition);
    transform: translateX(-4px);
  }

  .footer-link:hover {
    color: var(--color-white);
    padding-left: 4px;
  }

  .footer-link:hover .link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .contact-item a {
    color: rgba(255, 255, 255, 0.5);
    transition: var(--transition);
  }

  .contact-item a:hover {
    color: var(--color-primary);
  }

  .contact-icon {
    color: var(--color-primary);
    margin-top: 4px;
    min-width: 16px;
    opacity: 0.8;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-details strong {
    color: var(--color-primary);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 20px 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy,
  .footer-credit {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.25);
  }

  .footer-credit a {
    color: rgba(232, 180, 0, 0.6);
    transition: var(--transition);
  }
  .footer-credit a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
